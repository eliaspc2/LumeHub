{
  "name": "lume-hub-source",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "typecheck": "corepack pnpm -r --if-present typecheck",
    "build": "corepack pnpm -r --if-present build",
    "test": "corepack pnpm -r --if-present test",
    "test:unit": "node --test ./tests/unit",
    "test:integration": "node --test ./tests/integration",
    "test:e2e": "node --test ./tests/e2e",
    "package:wave12": "corepack pnpm -r --if-present build && node ./scripts/package-wave12.mjs",
    "validate:wave1": "corepack pnpm -r --if-present build && node ./scripts/validate-wave1.mjs",
    "validate:wave2": "corepack pnpm -r --if-present build && node ./scripts/validate-wave2.mjs",
    "validate:wave3": "corepack pnpm -r --if-present build && node ./scripts/validate-wave3.mjs",
    "validate:wave4": "corepack pnpm -r --if-present build && node ./scripts/validate-wave4.mjs",
    "validate:wave5": "corepack pnpm -r --if-present build && node ./scripts/validate-wave5.mjs",
    "validate:wave6": "corepack pnpm -r --if-present build && node ./scripts/validate-wave6.mjs",
    "validate:wave7": "corepack pnpm -r --if-present build && node ./scripts/validate-wave7.mjs",
    "validate:wave8": "corepack pnpm -r --if-present build && node ./scripts/validate-wave8.mjs",
    "validate:wave9": "corepack pnpm -r --if-present build && node ./scripts/validate-wave9.mjs",
    "validate:wave10": "corepack pnpm -r --if-present build && node ./scripts/validate-wave10.mjs",
    "validate:wave11": "corepack pnpm -r --if-present build && corepack pnpm run test:unit && corepack pnpm run test:integration && corepack pnpm run test:e2e",
    "validate:wave12": "corepack pnpm -r --if-present build && node ./scripts/validate-wave12.mjs && node ./scripts/package-wave12.mjs",
    "validate:wave13": "corepack pnpm run typecheck && corepack pnpm -r --if-present build && node ./scripts/validate-wave13.mjs",
    "preview:wave13": "corepack pnpm --filter @lume-hub/lume-hub-web preview -- --host 127.0.0.1 --port 4173 --strictPort"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  }
}
